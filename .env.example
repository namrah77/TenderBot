# TenderBot environment template — copy to `.env` and fill in real values.
# NEVER commit your real `.env` (it is git-ignored). Rotate any key that leaks.

# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY="your-gemini-api-key-here"

# Use the Gemini Developer API (not Vertex AI) for local runs.
GOOGLE_GENAI_USE_VERTEXAI=False

# Model used by every agent in the pipeline.
# flash-lite has higher free-tier limits and lower token cost than flash.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional — only needed if you enable Google Drive report upload via MCP.
# DRIVE_FOLDER_ID=your-shared-drive-folder-id

# Set to true for one-run pipeline verification logs (stdout + session state).
# PIPELINE_DEBUG=true

# Optional — required only for live integration tests (tests/integration/).
# TEST_COMPANY_URL=https://yourcompany.co.uk
